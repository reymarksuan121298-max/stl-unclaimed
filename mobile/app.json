        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.lordshin124.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/stl-logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "f4a3289c-5e78-4d59-a6f9-753a41fa0adc"
      }
    },
    "owner": "lordshin124"
