{
  "expo": {
    "name": "STL Unclaimed",
    "slug": "stl-unclaimed-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/stl-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/stl-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/stl-logo.png",
        "backgroundColor": "#6366f1"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.anonymous.stlunclaimedmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow STL Unclaimed to access your photos.",
          "savePhotosPermission": "Allow STL Unclaimed to save photos.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9f943f02-4897-4704-8e68-d7c093b10ea8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9f943f02-4897-4704-8e68-d7c093b10ea8"
    },
    "owner": "lordshin13"
  }
}
